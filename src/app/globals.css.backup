@import "tailwindcss";
@import "shadcn/tailwind.css";

@custom-variant dark (&:is(.dark *));

:root {
  --radius: 0.75rem;
  --background: oklch(0.98 0.005 270);
  --foreground: oklch(0.15 0.02 270);
  --card: oklch(0.99 0 0 / 80%);
  --card-foreground: oklch(0.15 0.02 270);
  --popover: oklch(0.99 0 0);
  --popover-foreground: oklch(0.15 0.02 270);
  --primary: oklch(0.55 0.22 265);
  --primary-foreground: oklch(0.98 0 0);
  --secondary: oklch(0.95 0.01 270);
  --secondary-foreground: oklch(0.25 0.02 270);
  --muted: oklch(0.95 0.01 270);
  --muted-foreground: oklch(0.5 0.02 270);
  --accent: oklch(0.94 0.02 270);
  --accent-foreground: oklch(0.25 0.02 270);
  --destructive: oklch(0.6 0.24 25);
  --border: oklch(0.9 0.01 270);
  --input: oklch(0.9 0.01 270);
  --ring: oklch(0.55 0.22 265);
  /* Vibrant chart colors */
  --chart-1: oklch(0.65 0.25 265);
  --chart-2: oklch(0.72 0.19 170);
  --chart-3: oklch(0.78 0.18 80);
  --chart-4: oklch(0.65 0.25 310);
  --chart-5: oklch(0.68 0.24 350);
  --sidebar: oklch(0.98 0.005 270);
  --sidebar-foreground: oklch(0.15 0.02 270);
  --sidebar-primary: oklch(0.55 0.22 265);
  --sidebar-primary-foreground: oklch(0.98 0 0);
  --sidebar-accent: oklch(0.94 0.02 265);
  --sidebar-accent-foreground: oklch(0.25 0.02 270);
  --sidebar-border: oklch(0.9 0.01 270);
  --sidebar-ring: oklch(0.55 0.22 265);
}

.dark {
  --background: oklch(0.12 0.02 265);
  --foreground: oklch(0.93 0.01 270);
  --card: oklch(0.16 0.025 265 / 60%);
  --card-foreground: oklch(0.93 0.01 270);
  --popover: oklch(0.16 0.025 265);
  --popover-foreground: oklch(0.93 0.01 270);
  --primary: oklch(0.65 0.25 265);
  --primary-foreground: oklch(0.98 0 0);
  --secondary: oklch(0.2 0.02 265);
  --secondary-foreground: oklch(0.9 0.01 270);
  --muted: oklch(0.2 0.02 265);
  --muted-foreground: oklch(0.6 0.02 270);
  --accent: oklch(0.22 0.03 265);
  --accent-foreground: oklch(0.9 0.01 270);
  --destructive: oklch(0.65 0.24 25);
  --border: oklch(0.25 0.03 265);
  --input: oklch(0.25 0.03 265);
  --ring: oklch(0.65 0.25 265);
  /* Vibrant chart colors for dark */
  --chart-1: oklch(0.7 0.22 265);
  --chart-2: oklch(0.75 0.17 170);
  --chart-3: oklch(0.8 0.18 80);
  --chart-4: oklch(0.72 0.22 310);
  --chart-5: oklch(0.7 0.22 350);
  --sidebar: oklch(0.12 0.025 265);
  --sidebar-foreground: oklch(0.93 0.01 270);
  --sidebar-primary: oklch(0.65 0.25 265);
  --sidebar-primary-foreground: oklch(0.98 0 0);
  --sidebar-accent: oklch(0.2 0.03 265);
  --sidebar-accent-foreground: oklch(0.93 0.01 270);
  --sidebar-border: oklch(0.25 0.03 265);
  --sidebar-ring: oklch(0.65 0.25 265);
}

@theme inline {
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);
  --radius-2xl: calc(var(--radius) + 8px);
  --radius-3xl: calc(var(--radius) + 12px);
  --radius-4xl: calc(var(--radius) + 16px);
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);
  --color-sidebar: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-ring: var(--sidebar-ring);

  /* Collapsible animations */
  --animate-collapsible-down: collapsible-down 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  --animate-collapsible-up: collapsible-up 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes collapsible-down {
  from { height: 0; opacity: 0; }
  to   { height: var(--radix-collapsible-content-height); opacity: 1; }
}
@keyframes collapsible-up {
  from { height: var(--radix-collapsible-content-height); opacity: 1; }
  to   { height: 0; opacity: 0; }
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  body {
    @apply bg-background text-foreground;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }
}

/* === Glassmorphism Effects === */

/* Animated orbs */
body::before,
body::after {
  content: '';
  position: fixed;
  border-radius: 50%;
  filter: blur(100px);
  z-index: 0;
  pointer-events: none;
  opacity: 0.6;
}

body::before {
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, oklch(0.6 0.22 265 / 25%), transparent 70%);
  top: -200px;
  right: -100px;
  animation: orb1 22s ease-in-out infinite;
}

body::after {
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, oklch(0.65 0.22 310 / 20%), transparent 70%);
  bottom: -150px;
  left: -50px;
  animation: orb2 28s ease-in-out infinite;
}

@keyframes orb1 {

  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }

  50% {
    transform: translate(-80px, 60px) scale(1.05);
  }
}

@keyframes orb2 {

  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }

  50% {
    transform: translate(60px, -80px) scale(1.08);
  }
}

/* Glassmorphism card override */
.dark [data-slot="card"] {
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 8px 32px oklch(0 0 0 / 15%), inset 0 1px 0 oklch(1 0 0 / 3%);
  transition: all 0.3s ease;
}

.dark [data-slot="card"]:hover {
  box-shadow: 0 16px 48px oklch(0.55 0.22 265 / 8%), inset 0 1px 0 oklch(1 0 0 / 5%);
  transform: translateY(-2px);
}

/* Light mode card shadow */
[data-slot="card"] {
  transition: all 0.3s ease;
}

[data-slot="card"]:hover {
  box-shadow: 0 12px 40px oklch(0.55 0.22 265 / 6%);
  transform: translateY(-2px);
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 4px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: oklch(0.5 0.15 265 / 20%);
  border-radius: 4px;
}

/* Pulse dot */
@keyframes pulse-dot {

  0%,
  100% {
    opacity: 1;
    transform: scale(1);
  }

  50% {
    opacity: 0.3;
    transform: scale(0.7);
  }
}

.pulse-dot {
  animation: pulse-dot 2s infinite;
}

/* Sidebar glassmorphism in dark */
.dark [data-sidebar="sidebar"] {
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}